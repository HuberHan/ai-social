.container {
  min-height: 100vh;
  background: linear-gradient(160deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
  padding: 48rpx 40rpx 80rpx;
  box-sizing: border-box;
}

/* VIP 当前状态 */
.vip-status {
  background: rgba(255, 215, 0, 0.15);
  border: 1rpx solid rgba(255, 215, 0, 0.4);
  border-radius: 16rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 40rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}
.vip-status__icon { font-size: 36rpx; }
.vip-status__text { font-size: 28rpx; color: #ffd700; }
.vip-status__sub  { font-size: 24rpx; color: rgba(255,215,0,0.6); }

/* 权益列表 */
.benefits {
  margin-bottom: 48rpx;
}
.benefits__title {
  font-size: 32rpx;
  font-weight: bold;
  color: #ffd700;
  margin-bottom: 28rpx;
  display: block;
}
.benefit-item {
  display: flex;
  align-items: flex-start;
  gap: 24rpx;
  margin-bottom: 28rpx;
}
.benefit-item__icon { font-size: 44rpx; flex-shrink: 0; }
.benefit-item__content {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}
.benefit-item__title { font-size: 30rpx; color: #fff; font-weight: bold; }
.benefit-item__desc  { font-size: 24rpx; color: rgba(255,255,255,0.55); }

/* 套餐卡片 */
.plans {
  display: flex;
  gap: 24rpx;
  margin-bottom: 48rpx;
}
.plan-card {
  flex: 1;
  background: rgba(255,255,255,0.08);
  border: 2rpx solid rgba(255,255,255,0.15);
  border-radius: 20rpx;
  padding: 32rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  position: relative;
  transition: border-color 0.2s;
}
.plan-card--selected {
  background: rgba(255, 215, 0, 0.12);
  border-color: #ffd700;
}
.plan-card__badge {
  position: absolute;
  top: -20rpx;
  left: 50%;
  transform: translateX(-50%);
  background: #ffd700;
  color: #1a1a2e;
  font-size: 20rpx;
  font-weight: bold;
  padding: 4rpx 20rpx;
  border-radius: 20rpx;
}
.plan-card__label { font-size: 28rpx; color: #fff; font-weight: bold; }
.plan-card__pricing {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}
.plan-card__price    { font-size: 48rpx; color: #ffd700; font-weight: bold; }
.plan-card__original { font-size: 24rpx; color: rgba(255,255,255,0.35); text-decoration: line-through; }
.plan-card__desc     { font-size: 22rpx; color: rgba(255,255,255,0.5); text-align: center; }

/* 购买按钮 */
.btn-purchase {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: linear-gradient(90deg, #f7b733, #fc4a1a);
  color: #fff;
  font-size: 34rpx;
  font-weight: bold;
  border-radius: 48rpx;
  border: none;
  margin-bottom: 28rpx;
}

.notice {
  display: block;
  text-align: center;
  font-size: 22rpx;
  color: rgba(255,255,255,0.3);
}
